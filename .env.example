# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=foreign_exchange_trading

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=30

# OTP
OTP_EXPIRY_MINUTES=10

# Mail (Gmail SMTP example)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="Foreign Exchange Trading <noreply@foreign-exchange-trading.app>"

# FX Rate API
FX_API_KEY=your_exchangerate_api_key
FX_API_BASE_URL=https://v6.exchangerate-api.com/v6

# Base currency
BASE_CURRENCY=NGN

# Supported currencies (comma-separated)
SUPPORTED_CURRENCIES=NGN,USD,EUR,GBP,CAD

# Cache TTL for FX rates (seconds)
FX_RATE_CACHE_TTL=60

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Logging (Loggly — https://www.loggly.com/)
# Leave blank to disable remote log shipping (local Winston console logging still active)
LOGGLY_TOKEN=your_loggly_customer_token

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000
